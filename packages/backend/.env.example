JWT_PRIVATE_KEY=replace_with_generated_private_key
JWKS=replace_with_generated_jwks_json

# Used for SIWE origin/domain verification
WALLET_AUTH_APP_URL=http://localhost:3000

# Optional: comma-separated numeric chain ids
# Example: 1,11155111,8453,84532,137,80002,10,11155420,42161,421614
WALLET_AUTH_CHAIN_IDS=1,11155111,8453,84532,137,80002,10,11155420,42161,421614
